import type { Metadata } from "next"
import Link from "next/link"
import { siteConfig, arcgisDepartment, itDepartment, navItems, footerLinks, socialLinks } from "@/lib/data"
import Header from "@/components/header"
import Footer from "@/components/footer"
import PageTransition from "@/components/page-transition"
import { DynamicIcon } from "@/lib/dynamic-icon"
import { supabase } from "@/lib/supabase"
import type { Layanan } from "@/lib/database.types"

export const metadata: Metadata = {
  title: `Layanan — ${siteConfig.name}`,
  description: "Layanan ArcGIS dan IT end-to-end dari SAYBA ARC.",
}

export default async function ServicesPage() {
  const { data: layananItems, error } = await supabase
    .from("layanan")
    .select("*")
    .eq("status", "active")
    .order("created_at", { ascending: true })

  if (error) {
    console.error("Error fetching layanan:", error)
  }

  const allLayanan: Layanan[] = layananItems ?? []
  const arcgisLayanan = allLayanan.filter((s) => s.dept === "arcgis")
  const itLayanan = allLayanan.filter((s) => s.dept === "it")

  return (
    <main className="min-h-screen flex flex-col">
      <Header navItems={navItems} ctaText="Hubungi Kami" />

      {/* Hero */}
      <section className="bg-black py-20">
        <PageTransition>
          <div className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <span className="inline-block text-xs font-bold text-[#ff914d] uppercase tracking-widest mb-4">Yang Kami Tawarkan</span>
            <h1 className="text-4xl md:text-5xl font-bold text-white mb-4">Layanan Kami</h1>
            <p className="text-white/45 text-lg max-w-2xl mx-auto">
              Dua departemen spesialis — ArcGIS dan IT — siap memberikan solusi terbaik untuk kebutuhan organisasi Anda.
            </p>
          </div>
        </PageTransition>
      </section>

      {/* Services */}
      <section className="py-20 bg-white flex-1">
        <PageTransition delay={100}>
          <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">

            {/* Departemen ArcGIS */}
            <div>
              <div className="flex items-center gap-4 mb-8">
                <div className="w-10 h-10 rounded-xl bg-[#ff914d] flex items-center justify-center">
                  <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                  </svg>
                </div>
                <div>
                  <p className="text-xs font-bold text-[#ff914d] uppercase tracking-widest">Departemen</p>
                  <h2 className="text-2xl font-bold text-black">{arcgisDepartment.title}</h2>
                </div>
                <div className="flex-1 h-px bg-black/8" />
              </div>
              {arcgisLayanan.length === 0 ? (
                <p className="text-black/40">Belum ada layanan ArcGIS yang tersedia.</p>
              ) : (
                <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                  {arcgisLayanan.map((service) => (
                    <div key={service.id} className="bg-white rounded-2xl p-7 border border-black/8 hover:border-[#ff914d]/30 hover:shadow-xl hover:shadow-orange-50 transition-all duration-300 group relative overflow-hidden">
                      <div className="absolute bottom-0 left-0 h-0.5 w-0 group-hover:w-full bg-[#ff914d] transition-all duration-500" />
                      <div className="flex items-start gap-4">
                        <div className="w-12 h-12 rounded-xl bg-[#ff914d]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#ff914d]/20 transition-colors">
                          <DynamicIcon name={service.icon ?? "map"} color="#ff914d" size={24} />
                        </div>
                        <div>
                          <h3 className="text-lg font-bold text-black mb-2 group-hover:text-[#ff914d] transition-colors">{service.title}</h3>
                          <p className="text-black/50 leading-relaxed text-sm">{service.description}</p>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>

            {/* Departemen IT */}
            <div>
              <div className="flex items-center gap-4 mb-8">
                <div className="w-10 h-10 rounded-xl bg-black flex items-center justify-center">
                  <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                </div>
                <div>
                  <p className="text-xs font-bold text-black/40 uppercase tracking-widest">Departemen</p>
                  <h2 className="text-2xl font-bold text-black">{itDepartment.title}</h2>
                </div>
                <div className="flex-1 h-px bg-black/8" />
              </div>
              {itLayanan.length === 0 ? (
                <p className="text-black/40">Belum ada layanan IT yang tersedia.</p>
              ) : (
                <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                  {itLayanan.map((service) => (
                    <div key={service.id} className="bg-white rounded-2xl p-7 border border-black/8 hover:border-black/20 hover:shadow-xl hover:shadow-black/5 transition-all duration-300 group relative overflow-hidden">
                      <div className="absolute bottom-0 left-0 h-0.5 w-0 group-hover:w-full bg-black transition-all duration-500" />
                      <div className="flex items-start gap-4">
                        <div className="w-12 h-12 rounded-xl bg-black/5 flex items-center justify-center flex-shrink-0 group-hover:bg-black/10 transition-colors">
                          <DynamicIcon name={service.icon ?? "code"} color="#111111" size={24} />
                        </div>
                        <div>
                          <h3 className="text-lg font-bold text-black mb-2">{service.title}</h3>
                          <p className="text-black/50 leading-relaxed text-sm">{service.description}</p>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>

            {/* CTA */}
            <div className="text-center bg-black rounded-3xl p-10 relative overflow-hidden">
              <div className="absolute top-0 right-0 w-48 h-48 rounded-full bg-[#ff914d] opacity-[0.08] blur-3xl" />
              <div className="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-1 bg-[#ff914d] rounded-full" />
              <h2 className="text-2xl md:text-3xl font-bold text-white mb-3 relative z-10">Butuh solusi kustom?</h2>
              <p className="text-white/40 mb-6 relative z-10">Setiap organisasi memiliki tantangan unik. Mari diskusikan solusi yang tepat untuk Anda.</p>
              <Link href="/contact" className="inline-block px-8 py-3 rounded-xl font-semibold bg-[#ff914d] text-white hover:bg-[#e07b3a] transition-all duration-200 hover:scale-105 relative z-10">
                Diskusikan Proyek Anda
              </Link>
            </div>
          </div>
        </PageTransition>
      </section>

      <Footer footerLinks={footerLinks} socialLinks={socialLinks} />
    </main>
  )
}
