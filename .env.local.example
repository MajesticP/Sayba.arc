# Supabase — get these from your Supabase project dashboard
# Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase service role key — used ONLY on the server for admin writes (bypasses RLS)
# Dashboard > Project Settings > API > service_role key
# NEVER commit this value or expose it to the browser (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your production domain (no trailing slash) — required for auth redirects
NEXT_PUBLIC_SITE_URL=https://sayba.web.id
